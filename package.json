{
  "name": "prostor-backend",
  "version": "1.0.0",
  "type": "module",
  "main": ".output/server.cjs",
  "scripts": {
    "dev": "tsx watch app/server.ts",
    "build": "tsc --noEmit && node scripts/build.mjs",
    "start": "node .output/server.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/express": "^4.17.21",
    "@types/node": "^26.0.0",
    "eslint": "^9.28.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.33.1"
  }
}
